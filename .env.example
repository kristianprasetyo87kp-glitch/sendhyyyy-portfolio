# ─────────────────────────────────────────────
#  Sendhy Portfolio — Environment Variables
#  Salin file ini menjadi .env lalu isi nilainya
# ─────────────────────────────────────────────

# ── Email (Gmail SMTP) ──────────────────────
# Gunakan Gmail App Password, BUKAN password biasa
# Cara buat: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=sendhy22@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_TO=sendhy22@gmail.com

# ── Admin Panel ─────────────────────────────
# Password untuk login ke /admin
ADMIN_PASSWORD=gantiPasswordIni123!
# Rahasia untuk JWT token — isi string acak panjang
JWT_SECRET=ganti-dengan-random-string-panjang-sekali

# ── Server ──────────────────────────────────
PORT=3000
